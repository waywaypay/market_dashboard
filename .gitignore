# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Node
web/node_modules/
# NOTE: web/dist IS committed — deploys serve the dashboard instantly with no
# build step. After changing web/src, run `make build` and commit the result.

# Pipeline output (emails written by the FixtureEmailProvider)
out/

# Editors / OS
.DS_Store
.idea/
.vscode/

# TypeScript incremental build state
*.tsbuildinfo

# Pipeline artifacts — generated per run, NEVER committed. A committed
# fixture artifact is indistinguishable from live data on a deploy: any
# host whose boot refresh fails would serve synthetic stories as if they
# were this morning's market. The server answers 503 + refresh status
# until the first real run lands instead.
web/public/brief.json
web/public/briefs/
web/public/universes.json
web/dist/brief.json
web/dist/briefs/
web/dist/universes.json
